import { useMemo, useState, useEffect } from "react";
import { MapPin } from "lucide-react";
import { hubsAPI, type Hub } from "../services/api";

interface HubsPageProps {
  onViewHub: (id: string) => void;
}

export default function HubsPage({ onViewHub }: HubsPageProps) {
  const [hubs, setHubs] = useState<Hub[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [query, setQuery] = useState("");
  const [region, setRegion] = useState("All");

  // Fetch hubs from API
  useEffect(() => {
    const fetchHubs = async () => {
      try {
        setLoading(true);
        const data = await hubsAPI.getAll();
        setHubs(data);
        setError(null);
      } catch (err) {
        console.error("Failed to fetch hubs:", err);
        setError("Failed to load hubs. Please try again later.");
      } finally {
        setLoading(false);
      }
    };

    fetchHubs();
  }, []);

  const REGIONS = ["All", ...Array.from(new Set(hubs.map(h => h.region))).sort()];

  const filtered = useMemo(() => {
    const q = query.trim().toLowerCase();
    return hubs.filter(h => {
      if (region !== "All" && h.region !== region) return false;
      if (!q) return true;
      return h.name.toLowerCase().includes(q) || h.city.toLowerCase().includes(q) || h.postcode.toLowerCase().includes(q) || h.type.toLowerCase().includes(q);
    });
  }, [query, region, hubs]);

  const grouped = useMemo(() => {
    const map = new Map<string, Hub[]>();
    for (const h of filtered) {
      const list = map.get(h.region) ?? [];
      list.push(h);
      map.set(h.region, list);
    }
    return Array.from(map.entries()).sort(([a], [b]) => a.localeCompare(b));
  }, [filtered]);

  return (
    <div className="px-8 py-6">
      {/* Header */}
      <div className="mb-6">
        <h1 className="text-3xl font-black text-white tracking-tight">
          UK Tech & Learning <span className="text-[var(--accent-neon)]">Hubs</span>
        </h1>
        <p className="text-[var(--text-secondary)] text-sm mt-1">
          {hubs.length} places across the UK where young people can learn, build and connect
        </p>
      </div>

      {/* Search + filter */}
      <div className="sticky top-0 z-10 bg-[var(--bg-navy)] pb-4">
        <div className="relative mb-3">
          <svg className="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--text-secondary)]" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" />
          </svg>
          <input
            value={query}
            onChange={e => setQuery(e.target.value)}
            placeholder="Search city, postcode, or hub name..."
            className="w-full h-11 rounded-xl border border-[rgba(34,211,238,0.2)] bg-[rgba(13,148,136,0.08)] pl-10 pr-4 text-sm text-white placeholder:text-[var(--text-secondary)] outline-none focus:border-[var(--accent)]"
          />
        </div>
        <div className="flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {REGIONS.map(r => (
            <button
              key={r}
              onClick={() => setRegion(r)}
              className={`shrink-0 rounded-full px-3 py-1 text-xs font-medium border transition ${region === r ? "border-[var(--accent)] bg-[var(--card-teal)] text-white" : "border-[rgba(34,211,238,0.2)] text-[var(--text-secondary)] hover:text-white"}`}
            >
              {r}
            </button>
          ))}
        </div>
        <p className="mt-2 text-[10px] uppercase tracking-wider text-[var(--text-secondary)]">
          {filtered.length} hub{filtered.length === 1 ? "" : "s"} shown
        </p>
      </div>

      {/* Loading state */}
      {loading && (
        <div className="flex items-center justify-center py-12">
          <div className="text-center">
            <div className="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-[var(--accent-neon)]"></div>
            <p className="mt-3 text-sm text-[var(--text-secondary)]">Loading hubs...</p>
          </div>
        </div>
      )}

      {/* Error state */}
      {error && (
        <p className="rounded-2xl border border-red-500/30 bg-red-500/10 p-6 text-center text-sm text-red-400">
          {error}
        </p>
      )}

      {/* Hub list */}
      {!loading && !error && grouped.length === 0 && (
        <p className="rounded-2xl border border-[rgba(34,211,238,0.15)] bg-[rgba(13,148,136,0.05)] p-6 text-center text-sm text-[var(--text-secondary)]">
          No hubs match your search.
        </p>
      )}

      {!loading && !error && grouped.map(([regionName, hubs]) => (
        <section key={regionName} className="mb-6">
          <h2 className="text-[10px] font-bold uppercase tracking-widest text-[var(--accent-neon)] mb-2">
            {regionName} · {hubs.length}
          </h2>
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-2">
            {hubs.map(h => (
              <button
                key={h.id}
                onClick={() => onViewHub(h.id)}
                className="text-left rounded-2xl border border-[rgba(34,211,238,0.1)] bg-[rgba(13,148,136,0.06)] p-4 hover:border-[rgba(34,211,238,0.35)] hover:bg-[rgba(13,148,136,0.12)] transition-all group"
              >
                <div className="flex items-start justify-between gap-3">
                  <div className="min-w-0">
                    <h3 className="truncate text-sm font-semibold text-white leading-tight group-hover:text-[var(--accent-neon)] transition-colors">
                      {h.name}
                    </h3>
                    <p className="mt-0.5 text-xs text-[var(--text-secondary)] flex items-center gap-1">
                      <MapPin size={10} /> {h.city} · {h.postcode}
                    </p>
                  </div>
                  <div className="text-right shrink-0">
                    <p className="text-[10px] font-bold text-[var(--accent-neon)] uppercase tracking-wider">
                      {h.type}
                    </p>
                    <p className="text-[10px] text-[var(--text-secondary)]">{h.region}</p>
                  </div>
                </div>
              </button>
            ))}
          </div>
        </section>
      ))}
    </div>
  );
}
